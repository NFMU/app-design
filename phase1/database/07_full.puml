@startuml
hide circle
skinparam linetype ortho
skinparam packageStyle rectangle

package "Identity & User Management" {
  entity users {
    * id : bigint
    --
    uuid : char(36)
    email : varchar
    password_hash : varchar
    status : varchar
    auth_provider : varchar
    email_verified_at : datetime
    last_login_at : datetime
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }

  entity user_profiles {
    * user_id : bigint
    --
    display_name : varchar
    avatar_url : varchar
    job_title : varchar
    phone : varchar
    language_code : varchar
    timezone : varchar
    status : varchar
    bio : varchar
    created_at : datetime
    updated_at : datetime
  }

  entity user_settings {
    * user_id : bigint
    --
    notifications_json : json
    preferences_json : json
    created_at : datetime
    updated_at : datetime
  }

  entity user_sessions {
    * id : bigint
    --
    user_id : bigint
    session_token : varchar
    refresh_token_hash : varchar
    ip_address : varchar
    user_agent : varchar
    device_name : varchar
    last_seen_at : datetime
    expires_at : datetime
    revoked_at : datetime
    created_at : datetime
  }

  entity password_resets {
    * id : bigint
    --
    user_id : bigint
    token_hash : varchar
    expires_at : datetime
    used_at : datetime
    created_at : datetime
  }
}

package "Tenant & Subscription" {
  entity plans {
    * id : bigint
    --
    code : varchar
    name : varchar
    description : text
    max_members : int
    max_channels : int
    max_storage_gb : int
    features_json : json
    status : varchar
    created_at : datetime
    updated_at : datetime
  }

  entity tenants {
    * id : bigint
    --
    uuid : char(36)
    plan_id : bigint
    owner_user_id : bigint
    name : varchar
    slug : varchar
    domain : varchar
    status : varchar
    timezone : varchar
    locale : varchar
    branding_json : json
    settings_json : json
    activated_at : datetime
    suspended_at : datetime
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }

  entity tenant_members {
    * id : bigint
    --
    tenant_id : bigint
    user_id : bigint
    status : varchar
    joined_at : datetime
    invited_by : bigint
    left_at : datetime
    removed_at : datetime
    created_at : datetime
    updated_at : datetime
  }

  entity invitations {
    * id : bigint
    --
    tenant_id : bigint
    channel_id : bigint
    email : varchar
    invite_type : varchar
    token : varchar
    role_scope : varchar
    role_code : varchar
    status : varchar
    expires_at : datetime
    invited_by : bigint
    accepted_by_user_id : bigint
    accepted_at : datetime
    created_at : datetime
    updated_at : datetime
  }
}

package "Channels & Messages" {
  entity channels {
    * id : bigint
    --
    uuid : char(36)
    tenant_id : bigint
    name : varchar
    slug : varchar
    channel_type : varchar
    description : text
    topic : varchar
    avatar_url : varchar
    status : varchar
    settings_json : json
    created_by : bigint
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }

  entity channel_members {
    * id : bigint
    --
    channel_id : bigint
    user_id : bigint
    status : varchar
    notification_level : varchar
    is_pinned : boolean
    display_order : int
    joined_at : datetime
    added_by : bigint
    left_at : datetime
    created_at : datetime
    updated_at : datetime
  }

  entity messages {
    * id : bigint
    --
    uuid : char(36)
    channel_id : bigint
    sender_user_id : bigint
    parent_message_id : bigint
    message_type : varchar
    content_text : text
    metadata_json : json
    edited_at : datetime
    edited_by : bigint
    deleted_at : datetime
    deleted_by : bigint
    created_at : datetime
  }

  entity message_reads {
    * id : bigint
    --
    channel_id : bigint
    user_id : bigint
    last_read_message_id : bigint
    last_read_at : datetime
    updated_at : datetime
  }

  entity message_pins {
    * id : bigint
    --
    channel_id : bigint
    message_id : bigint
    pinned_by : bigint
    pinned_at : datetime
    unpinned_at : datetime
  }

  entity message_attachments {
    * id : bigint
    --
    message_id : bigint
    file_name : varchar
    mime_type : varchar
    file_size : bigint
    storage_path : varchar
    url : varchar
    thumbnail_url : varchar
    created_at : datetime
  }
}

package "Authorization (RBAC)" {
  entity roles {
    * id : bigint
    --
    tenant_id : bigint
    scope_type : varchar
    code : varchar
    name : varchar
    description : varchar
    is_system : boolean
    created_at : datetime
    updated_at : datetime
  }

  entity permissions {
    * id : bigint
    --
    scope_type : varchar
    code : varchar
    name : varchar
    description : varchar
    created_at : datetime
  }

  entity role_permissions {
    * id : bigint
    --
    role_id : bigint
    permission_id : bigint
  }

  entity tenant_member_roles {
    * id : bigint
    --
    tenant_member_id : bigint
    role_id : bigint
    assigned_by : bigint
    assigned_at : datetime
  }

  entity channel_member_roles {
    * id : bigint
    --
    channel_member_id : bigint
    role_id : bigint
    assigned_by : bigint
    assigned_at : datetime
  }
}

' Identity relationships
users ||--|| user_profiles
users ||--|| user_settings
users ||--o{ user_sessions
users ||--o{ password_resets

' Tenant relationships
plans ||--o{ tenants
tenants ||--o{ tenant_members
tenants ||--o{ channels
tenants ||--o{ invitations
tenants ||--o{ roles

' Membership relationships
users ||--o{ tenant_members

' Channel relationships
channels ||--o{ channel_members
channels ||--o{ messages
channels ||--o{ message_reads
channels ||--o{ message_pins
channels ||--o{ invitations

' Message relationships
messages ||--o{ messages : parent
messages ||--o{ message_reads
messages ||--o{ message_pins
messages ||--o{ message_attachments

' User relationships with channels and messages
users ||--o{ channel_members
users ||--o{ messages

' RBAC relationships
roles ||--o{ role_permissions
permissions ||--o{ role_permissions
tenant_members ||--o{ tenant_member_roles
channel_members ||--o{ channel_member_roles
roles ||--o{ tenant_member_roles
roles ||--o{ channel_member_roles
@enduml
