@startuml
hide circle
skinparam linetype ortho
skinparam packageStyle rectangle

package "Identity" {
  entity users {
    * id : bigint
    --
    uuid : char(36)
    email : varchar
    password_hash : varchar
    account_status : varchar
    auth_provider : varchar
    email_verified_at : datetime
    last_login_at : datetime
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }

  entity user_profiles {
    * user_id : bigint
    --
    display_name : varchar
    avatar_url : varchar
    job_title : varchar
    internal_phone : varchar
    language_code : varchar
    timezone : varchar
    presence_status : varchar
    created_at : datetime
    updated_at : datetime
  }

  entity user_settings {
    * user_id : bigint
    --
    notification_level : varchar
    notification_config_json : json
    preference_json : json
    created_at : datetime
    updated_at : datetime
  }

  entity user_sessions {
    * id : bigint
    --
    user_id : bigint
    session_token : varchar
    refresh_token_hash : varchar
    ip_address : varchar
    user_agent : varchar
    device_name : varchar
    is_current : boolean
    last_seen_at : datetime
    expired_at : datetime
    revoked_at : datetime
    created_at : datetime
  }

  entity password_resets {
    * id : bigint
    --
    user_id : bigint
    token_hash : varchar
    expired_at : datetime
    used_at : datetime
    created_at : datetime
  }
}

package "Tenant Foundation" {
  entity plans {
    * id : bigint
    --
    code : varchar
    name : varchar
    status : varchar
    config_json : json
    created_at : datetime
    updated_at : datetime
  }

  entity tenants {
    * id : bigint
    --
    uuid : char(36)
    plan_id : bigint
    owner_user_id : bigint
    name : varchar
    tenant_code : varchar
    domain : varchar
    status : varchar
    timezone : varchar
    locale : varchar
    branding_json : json
    policy_flags_json : json
    metadata_json : json
    activated_at : datetime
    suspended_at : datetime
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }

  entity workspaces {
    * id : bigint
    --
    uuid : char(36)
    tenant_id : bigint
    code : varchar
    name : varchar
    description : text
    logo_url : varchar
    status : varchar
    is_default : boolean
    rules_json : json
    metadata_json : json
    created_by : bigint
    updated_by : bigint
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }
}

package "Membership" {
  entity tenant_members {
    * id : bigint
    --
    tenant_id : bigint
    user_id : bigint
    status : varchar
    joined_at : datetime
    invited_by : bigint
    invited_at : datetime
    removed_at : datetime
    created_at : datetime
    updated_at : datetime
  }

  entity workspace_members {
    * id : bigint
    --
    tenant_id : bigint
    workspace_id : bigint
    user_id : bigint
    status : varchar
    joined_at : datetime
    invited_by : bigint
    invited_at : datetime
    left_at : datetime
    removed_at : datetime
    created_at : datetime
    updated_at : datetime
  }

  entity channels {
    * id : bigint
    --
    uuid : char(36)
    tenant_id : bigint
    workspace_id : bigint
    code : varchar
    name : varchar
    slug : varchar
    channel_type : varchar
    description : text
    topic : varchar
    avatar_url : varchar
    status : varchar
    rules_json : json
    metadata_json : json
    created_by : bigint
    updated_by : bigint
    created_at : datetime
    updated_at : datetime
    deleted_at : datetime
  }

  entity channel_members {
    * id : bigint
    --
    tenant_id : bigint
    workspace_id : bigint
    channel_id : bigint
    user_id : bigint
    membership_status : varchar
    joined_at : datetime
    added_by : bigint
    notification_level : varchar
    is_pinned : boolean
    display_order : int
    hidden_at : datetime
    left_at : datetime
    removed_at : datetime
    created_at : datetime
    updated_at : datetime
  }

  entity invitations {
    * id : bigint
    --
    tenant_id : bigint
    workspace_id : bigint
    email : varchar
    invite_type : varchar
    token : varchar
    intended_role_scope : varchar
    intended_role_code : varchar
    status : varchar
    expires_at : datetime
    invited_by : bigint
    accepted_by_user_id : bigint
    accepted_at : datetime
    created_at : datetime
    updated_at : datetime
  }
}

package "Chat" {
  entity messages {
    * id : bigint
    --
    uuid : char(36)
    tenant_id : bigint
    workspace_id : bigint
    channel_id : bigint
    sender_user_id : bigint
    parent_message_id : bigint
    message_type : varchar
    content_text : text
    metadata_json : json
    is_edited : boolean
    edited_at : datetime
    edited_by : bigint
    is_deleted : boolean
    deleted_at : datetime
    deleted_by : bigint
    created_at : datetime
    updated_at : datetime
  }

  entity message_reads {
    * id : bigint
    --
    tenant_id : bigint
    workspace_id : bigint
    channel_id : bigint
    user_id : bigint
    last_read_message_id : bigint
    last_read_at : datetime
    created_at : datetime
    updated_at : datetime
  }

  entity message_pins {
    * id : bigint
    --
    tenant_id : bigint
    workspace_id : bigint
    channel_id : bigint
    message_id : bigint
    pinned_by : bigint
    pinned_at : datetime
    unpinned_at : datetime
  }

  entity message_attachments {
    * id : bigint
    --
    message_id : bigint
    attachment_type : varchar
    storage_provider : varchar
    file_name : varchar
    mime_type : varchar
    file_size : bigint
    url : varchar
    metadata_json : json
    created_at : datetime
  }
}

package "Authorization" {
  entity roles {
    * id : bigint
    --
    tenant_id : bigint
    scope_type : varchar
    code : varchar
    name : varchar
    is_system : boolean
    created_at : datetime
    updated_at : datetime
  }

  entity permissions {
    * id : bigint
    --
    scope_type : varchar
    code : varchar
    name : varchar
    description : varchar
  }

  entity role_permissions {
    * id : bigint
    --
    role_id : bigint
    permission_id : bigint
  }

  entity tenant_member_roles {
    * id : bigint
    --
    tenant_member_id : bigint
    role_id : bigint
  }

  entity workspace_member_roles {
    * id : bigint
    --
    workspace_member_id : bigint
    role_id : bigint
  }

  entity channel_member_roles {
    * id : bigint
    --
    channel_member_id : bigint
    role_id : bigint
  }
}

users ||--|| user_profiles
users ||--|| user_settings
users ||--o{ user_sessions
users ||--o{ password_resets

plans ||--o{ tenants
tenants ||--o{ workspaces
tenants ||--o{ tenant_members
tenants ||--o{ workspace_members
tenants ||--o{ channels
tenants ||--o{ invitations
tenants ||--o{ roles

workspaces ||--o{ workspace_members
workspaces ||--o{ channels
workspaces ||--o{ invitations

channels ||--o{ channel_members
channels ||--o{ messages
channels ||--o{ message_reads
channels ||--o{ message_pins

messages ||--o{ messages : parent
messages ||--o{ message_reads
messages ||--o{ message_pins
messages ||--o{ message_attachments

roles ||--o{ role_permissions
permissions ||--o{ role_permissions

tenant_members ||--o{ tenant_member_roles
workspace_members ||--o{ workspace_member_roles
channel_members ||--o{ channel_member_roles

roles ||--o{ tenant_member_roles
roles ||--o{ workspace_member_roles
roles ||--o{ channel_member_roles
@enduml