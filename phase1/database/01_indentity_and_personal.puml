@startuml
hide circle
skinparam linetype ortho

entity users {
  * id : bigint <<PK>>
  --
  uuid : char(36) <<UQ>>
  email : varchar(255) <<UQ>>
  password_hash : varchar(255)
  account_status : varchar(30)
  auth_provider : varchar(30)
  email_verified_at : datetime
  last_login_at : datetime
  created_at : datetime
  updated_at : datetime
  deleted_at : datetime
}

entity user_profiles {
  * user_id : bigint <<PK, FK>>
  --
  display_name : varchar(255)
  avatar_url : varchar(500)
  job_title : varchar(255)
  internal_phone : varchar(50)
  language_code : varchar(20)
  timezone : varchar(100)
  presence_status : varchar(30)
  about_text : varchar(500)
  created_at : datetime
  updated_at : datetime
}

entity user_settings {
  * user_id : bigint <<PK, FK>>
  --
  notification_level : varchar(30)
  notification_config_json : json
  preference_json : json
  created_at : datetime
  updated_at : datetime
}

entity user_sessions {
  * id : bigint <<PK>>
  --
  user_id : bigint <<FK>>
  session_token : varchar(255) <<UQ>>
  refresh_token_hash : varchar(255)
  ip_address : varchar(64)
  user_agent : varchar(500)
  device_name : varchar(255)
  is_current : boolean
  last_seen_at : datetime
  expired_at : datetime
  revoked_at : datetime
  created_at : datetime
}

entity password_resets {
  * id : bigint <<PK>>
  --
  user_id : bigint <<FK>>
  token_hash : varchar(255)
  expired_at : datetime
  used_at : datetime
  created_at : datetime
}

users ||--|| user_profiles
users ||--|| user_settings
users ||--o{ user_sessions
users ||--o{ password_resets
@enduml