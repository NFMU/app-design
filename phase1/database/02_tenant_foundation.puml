@startuml
hide circle
skinparam linetype ortho

entity plans {
  * id : bigint <<PK>>
  --
  code : varchar(50) <<UQ>>
  name : varchar(100)
  description : text
  max_members : int
  max_channels : int
  max_storage_gb : int
  features_json : json
  status : varchar(30)
  created_at : datetime
  updated_at : datetime
}

entity tenants {
  * id : bigint <<PK>>
  --
  uuid : char(36) <<UQ>>
  plan_id : bigint <<FK>>
  owner_user_id : bigint <<FK>>
  name : varchar(255)
  slug : varchar(100) <<UQ>>
  domain : varchar(255)
  status : varchar(30)
  timezone : varchar(50)
  locale : varchar(10)
  branding_json : json
  settings_json : json
  activated_at : datetime
  suspended_at : datetime
  created_at : datetime
  updated_at : datetime
  deleted_at : datetime
}

note right of tenants::branding_json
  {
    "logo_url": "...",
    "primary_color": "#...",
    "theme": "light|dark"
  }
end note

note right of tenants::settings_json
  {
    "invite_policy": "admin_only|members",
    "retention_days": 90,
    "allowed_domains": ["@company.com"]
  }
end note

plans ||--o{ tenants
@enduml
