@startuml
hide circle
skinparam linetype ortho

entity tenant_members {
  * id : bigint <<PK>>
  --
  tenant_id : bigint <<FK>>
  user_id : bigint <<FK>>
  status : varchar(30)
  joined_at : datetime
  invited_by : bigint <<FK>>
  left_at : datetime
  removed_at : datetime
  created_at : datetime
  updated_at : datetime
}

note right of tenant_members::status
  active | suspended | left
end note

entity channel_members {
  * id : bigint <<PK>>
  --
  channel_id : bigint <<FK>>
  user_id : bigint <<FK>>
  status : varchar(30)
  notification_level : varchar(30)
  is_pinned : boolean
  display_order : int
  joined_at : datetime
  added_by : bigint <<FK>>
  left_at : datetime
  created_at : datetime
  updated_at : datetime
}

note right of channel_members::notification_level
  all | mentions | none
end note

entity invitations {
  * id : bigint <<PK>>
  --
  tenant_id : bigint <<FK>>
  channel_id : bigint <<FK, nullable>>
  email : varchar(255)
  invite_type : varchar(30)
  token : varchar(255) <<UQ>>
  role_scope : varchar(30)
  role_code : varchar(50)
  status : varchar(30)
  expires_at : datetime
  invited_by : bigint <<FK>>
  accepted_by_user_id : bigint <<FK>>
  accepted_at : datetime
  created_at : datetime
  updated_at : datetime
}

note right of invitations::invite_type
  tenant | channel
end note

note right of invitations::role_scope
  tenant | channel
end note

note right of invitations::status
  pending | accepted | expired | revoked
end note

@enduml
