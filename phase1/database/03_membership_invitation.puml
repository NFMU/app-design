@startuml
hide circle
skinparam linetype ortho

entity tenant_members {
  * id : bigint <<PK>>
  --
  tenant_id : bigint <<FK>>
  user_id : bigint <<FK>>
  status : varchar(30)
  joined_at : datetime
  invited_by : bigint <<FK>>
  invited_at : datetime
  removed_at : datetime
  created_at : datetime
  updated_at : datetime
}

entity workspace_members {
  * id : bigint <<PK>>
  --
  tenant_id : bigint <<FK>>
  workspace_id : bigint <<FK>>
  user_id : bigint <<FK>>
  status : varchar(30)
  joined_at : datetime
  invited_by : bigint <<FK>>
  invited_at : datetime
  left_at : datetime
  removed_at : datetime
  created_at : datetime
  updated_at : datetime
}

entity channel_members {
  * id : bigint <<PK>>
  --
  tenant_id : bigint <<FK>>
  workspace_id : bigint <<FK>>
  channel_id : bigint <<FK>>
  user_id : bigint <<FK>>
  membership_status : varchar(30)
  joined_at : datetime
  added_by : bigint <<FK>>
  notification_level : varchar(30)
  is_pinned : boolean
  display_order : int
  hidden_at : datetime
  left_at : datetime
  removed_at : datetime
  created_at : datetime
  updated_at : datetime
}

entity invitations {
  * id : bigint <<PK>>
  --
  tenant_id : bigint <<FK>>
  workspace_id : bigint <<FK>>
  email : varchar(255)
  invite_type : varchar(30)
  token : varchar(255) <<UQ>>
  intended_role_scope : varchar(30)
  intended_role_code : varchar(50)
  status : varchar(30)
  expires_at : datetime
  invited_by : bigint <<FK>>
  accepted_by_user_id : bigint <<FK>>
  accepted_at : datetime
  created_at : datetime
  updated_at : datetime
}
@enduml