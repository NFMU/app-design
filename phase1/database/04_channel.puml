@startuml
hide circle
skinparam linetype ortho

entity channels {
  * id : bigint <<PK>>
  --
  uuid : char(36) <<UQ>>
  tenant_id : bigint <<FK>>
  name : varchar(255)
  slug : varchar(255) <<UQ>>
  channel_type : varchar(30)
  description : text
  topic : varchar(500)
  avatar_url : varchar(500)
  status : varchar(30)
  settings_json : json
  created_by : bigint <<FK>>
  created_at : datetime
  updated_at : datetime
  deleted_at : datetime
}

note right of channels::channel_type
  public | private | direct_message
end note

note right of channels::status
  active | archived
end note

note right of channels::settings_json
  {
    "allow_threads": true,
    "read_only": false,
    "retention_days": null
  }
end note

entity channel_members {
  * id : bigint <<PK>>
  --
  channel_id : bigint <<FK>>
  user_id : bigint <<FK>>
  status : varchar(30)
  notification_level : varchar(30)
  is_pinned : boolean
  display_order : int
  joined_at : datetime
  added_by : bigint <<FK>>
  left_at : datetime
  created_at : datetime
  updated_at : datetime
}

note right of channel_members::status
  active | left
end note

note right of channel_members::notification_level
  all | mentions | none
end note

channels ||--o{ channel_members
@enduml
